public/
.DS_Store
node_modules/
*.local.json
.mise.local.toml

# Zola's giallo syntax-highlighter writes these into static/ from the
# [markdown.highlighting] config — fully derived from light_theme /
# dark_theme. Letting them regenerate on each fresh build keeps source
# config the single source of truth.
static/giallo-*.css

# Generated by scripts/extract-git-dates.py before each build. Derived
# from `git log -1 --format=%cs` per content file; falls back to mtime
# if git history isn't available.
data/updated-dates.json
